---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BlogCard from '../../components/BlogCard.astro';
import { site } from '../../data/site';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title={`Blog — ${site.name}`} description="Writing on data science, machine learning, and AI engineering.">
  <!-- Top bar -->
  <header class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-sm border-b border-zinc-800/50">
    <div class="max-w-2xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-xs text-zinc-500 hover:text-zinc-200 transition-colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        Portfolio
      </a>
      <span class="font-mono text-xs text-zinc-600">{site.name}</span>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-6 py-16">
    <div class="mb-10">
      <h1 class="text-2xl font-bold tracking-tight text-zinc-100 mb-2">Writing</h1>
      <p class="text-zinc-500 text-sm">Notes on data science, ML engineering, and applied AI.</p>
    </div>

    {sorted.length === 0 ? (
      <p class="text-zinc-600 text-sm">No posts yet.</p>
    ) : (
      <div class="space-y-3">
        {sorted.map(post => <BlogCard post={post} />)}
      </div>
    )}
  </main>

  <footer class="max-w-2xl mx-auto px-6 py-8 border-t border-zinc-800/50">
    <p class="font-mono text-[11px] text-zinc-700">{site.name} · {new Date().getFullYear()}</p>
  </footer>
</Base>
