---
export async function getStaticPaths() {
  // Old /notebooks/jupyter/[slug] URLs — redirect to /notebooks/[slug]
  const fs   = await import('node:fs');
  const path = await import('node:path');
  const dir  = path.join(process.cwd(), 'src/content/jupyter');
  if (!fs.existsSync(dir)) return [];
  const slugs = fs.readdirSync(dir)
    .filter((f: string) => f.endsWith('.ipynb'))
    .map((f: string) => f.replace('.ipynb', ''));
  return slugs.map((slug: string) => ({ params: { slug } }));
}

return Astro.redirect(`/notebooks/${Astro.params.slug}`, 301);
---
