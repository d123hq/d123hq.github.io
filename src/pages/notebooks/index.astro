---
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';
import fs from 'node:fs';
import path from 'node:path';

// Discover Jupyter notebooks
const jupyterDir = path.join(process.cwd(), 'src/content/jupyter');
const jupyterFiles = fs.existsSync(jupyterDir)
  ? fs.readdirSync(jupyterDir).filter(f => f.endsWith('.ipynb'))
  : [];

const jupyterNotebooks = jupyterFiles.map(file => {
  const slug = file.replace('.ipynb', '');
  const nb = JSON.parse(fs.readFileSync(path.join(jupyterDir, file), 'utf-8'));
  const meta = nb.metadata ?? {};
  return {
    slug,
    title:       meta.title       ?? slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()),
    description: meta.description ?? '',
    date:        meta.date        ?? '',
    tags:        meta.tags        ?? [],
  };
});

// Marimo notebooks listed from site config (user adds entries when exporting)
const marimoNotebooks = (site as any).marimoNotebooks ?? [];
---

<Base title={`Notebooks — ${site.name}`} description="Interactive notebooks on data science and machine learning.">
  <header class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-sm border-b border-zinc-800/50">
    <div class="max-w-2xl mx-auto px-6 h-14 flex items-center justify-between">
      <span class="font-mono text-sm text-white font-medium">{site.name}</span>
      <nav class="flex items-center gap-4">
        <a href="/" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Writing</a>
        <a href="/about" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">About →</a>
      </nav>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-6 py-16">
    <div class="mb-12">
      <h1 class="text-2xl font-bold tracking-tight text-zinc-100 mb-2">Notebooks</h1>
      <p class="text-zinc-500 text-sm">Interactive analyses, experiments, and explorations.</p>
    </div>

    <!-- Jupyter Notebooks -->
    <section class="mb-14">
      <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-zinc-600 mb-5">Jupyter</h2>
      {jupyterNotebooks.length === 0 ? (
        <p class="text-zinc-600 text-sm">No notebooks yet — add <code class="text-zinc-500 text-xs font-mono">.ipynb</code> files to <code class="text-zinc-500 text-xs font-mono">src/content/jupyter/</code></p>
      ) : (
        <div class="space-y-3">
          {jupyterNotebooks.map(nb => (
            <a href={`/notebooks/jupyter/${nb.slug}`}
               class="group block p-5 rounded-xl border border-zinc-800/60 bg-zinc-900/30 hover:border-zinc-700 hover:bg-zinc-900/60 transition-all">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-semibold text-zinc-100 group-hover:text-white transition-colors mb-1 leading-snug">{nb.title}</h3>
                  {nb.description && <p class="text-xs text-zinc-500 leading-relaxed line-clamp-2">{nb.description}</p>}
                </div>
                <span class="shrink-0 font-mono text-[10px] text-zinc-700 border border-zinc-800 rounded px-1.5 py-0.5">ipynb</span>
              </div>
              {nb.date && (
                <p class="font-mono text-[11px] text-zinc-700 mt-3">
                  {new Date(nb.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                </p>
              )}
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- Marimo Notebooks -->
    <section class="mb-14">
      <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-zinc-600 mb-5">Marimo</h2>
      {marimoNotebooks.length === 0 ? (
        <div class="p-5 rounded-xl border border-zinc-800/60 bg-zinc-900/20">
          <p class="text-zinc-500 text-sm mb-3">Export a Marimo notebook to add it here:</p>
          <pre class="font-mono text-xs text-zinc-400 bg-zinc-900 rounded-lg p-3 overflow-x-auto">marimo export html-wasm notebook.py \
  -o public/notebooks/my-notebook.html</pre>
          <p class="text-zinc-600 text-xs mt-3">Then add an entry to <code class="text-zinc-500 font-mono">marimoNotebooks</code> in <code class="text-zinc-500 font-mono">src/data/site.ts</code>.</p>
        </div>
      ) : (
        <div class="space-y-3">
          {marimoNotebooks.map((nb: any) => (
            <a href={nb.href} target="_blank" rel="noopener"
               class="group flex items-center justify-between p-5 rounded-xl border border-zinc-800/60 bg-zinc-900/30 hover:border-zinc-700 hover:bg-zinc-900/60 transition-all">
              <div>
                <h3 class="text-sm font-semibold text-zinc-100 group-hover:text-white transition-colors mb-1">{nb.title}</h3>
                {nb.desc && <p class="text-xs text-zinc-500 leading-relaxed">{nb.desc}</p>}
              </div>
              <span class="shrink-0 font-mono text-[10px] text-zinc-700 border border-zinc-800 rounded px-1.5 py-0.5 ml-4">marimo</span>
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- Interactive Blog Posts -->
    <section>
      <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-zinc-600 mb-3">Interactive posts</h2>
      <p class="text-zinc-600 text-xs leading-relaxed">
        Some writing includes live Python cells powered by Pyodide — code runs directly in your browser, no server needed.
        Look for the <span class="font-mono text-violet-500">▶ Run</span> button inside posts.
        <a href="/" class="text-zinc-500 hover:text-zinc-200 transition-colors ml-1">Browse writing →</a>
      </p>
    </section>
  </main>

  <footer class="max-w-2xl mx-auto px-6 py-8 border-t border-zinc-800/50">
    <p class="font-mono text-[11px] text-zinc-700">{site.name} · {new Date().getFullYear()}</p>
  </footer>
</Base>
