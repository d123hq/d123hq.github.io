---
import Base from './Base.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description: string;
  colabUrl: string;
  date?: string;
}

const { title, description, colabUrl, date } = Astro.props;

const formattedDate = date
  ? new Date(date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;
---

<Base title={`${title} — ${site.name}`} description={description}>
  <header class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-sm border-b border-zinc-800/50">
    <div class="max-w-3xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/notebooks" class="flex items-center gap-2 text-xs text-zinc-500 hover:text-zinc-200 transition-colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        Notebooks
      </a>
      <nav class="flex items-center gap-4">
        <a href={colabUrl} target="_blank" rel="noopener"
           class="flex items-center gap-1.5 text-xs text-zinc-500 hover:text-orange-400 transition-colors">
          <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
            <path d="M16.9 4.8C14.9 2.8 12.4 1.8 9.7 1.8 4.5 1.8.2 6.1.2 11.3c0 2.8 1.2 5.4 3.1 7.2L16.9 4.8zm-1.4 14.4C13.6 21.1 11.7 22 9.7 22c-5.1 0-9.5-4.3-9.5-9.5 0-1.9.6-3.8 1.6-5.3l13.7 12zm8.3-7.9c0 2.8-1.2 5.4-3.1 7.2L7.1 4.8C9.1 2.8 11.6 1.8 14.3 1.8c5.2 0 9.5 4.3 9.5 9.5z"/>
          </svg>
          Open in Colab
        </a>
        <a href="/" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">Writing</a>
        <a href="/about" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">About</a>
      </nav>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="text-2xl lg:text-3xl font-bold tracking-tight text-zinc-100 leading-snug mb-3">{title}</h1>
      <p class="text-zinc-400 text-sm leading-relaxed mb-4">{description}</p>
      {formattedDate && (
        <p class="font-mono text-[11px] text-zinc-600">{formattedDate}</p>
      )}
    </div>

    <hr class="border-zinc-800/60 mb-10" />

    <slot />

    <div class="mt-16 pt-8 border-t border-zinc-800/50 flex items-center justify-between flex-wrap gap-4">
      <a href="/notebooks" class="flex items-center gap-2 text-xs text-zinc-500 hover:text-zinc-200 transition-colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        All notebooks
      </a>
      <a href={colabUrl} target="_blank" rel="noopener"
         class="flex items-center gap-1.5 text-xs text-zinc-500 hover:text-orange-400 transition-colors">
        <svg viewBox="0 0 24 24" fill="currentColor" width="12" height="12">
          <path d="M16.9 4.8C14.9 2.8 12.4 1.8 9.7 1.8 4.5 1.8.2 6.1.2 11.3c0 2.8 1.2 5.4 3.1 7.2L16.9 4.8zm-1.4 14.4C13.6 21.1 11.7 22 9.7 22c-5.1 0-9.5-4.3-9.5 0-1.9.6-3.8 1.6-5.3l13.7 12zm8.3-7.9c0 2.8-1.2 5.4-3.1 7.2L7.1 4.8C9.1 2.8 11.6 1.8 14.3 1.8c5.2 0 9.5 4.3 9.5 9.5z"/>
        </svg>
        Open in Colab
      </a>
    </div>
  </main>
</Base>
