---
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import { site } from '../data/site';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, tags } = post.data;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});

// Rough reading-time estimate
const wordCount  = post.body.split(/\s+/).length;
const readingMin = Math.max(1, Math.round(wordCount / 200));
---

<Base title={`${title} — ${site.name}`} description={description}>
  <!-- Top bar -->
  <header class="sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-sm border-b border-zinc-800/50">
    <div class="max-w-2xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-xs text-zinc-500 hover:text-zinc-200 transition-colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        Writing
      </a>
      <a href="/about" class="text-xs text-zinc-500 hover:text-zinc-200 transition-colors">
        About
      </a>
    </div>
  </header>

  <!-- Article -->
  <main class="max-w-2xl mx-auto px-6 py-16">
    <!-- Header -->
    <div class="mb-10">
      <div class="flex flex-wrap gap-1.5 mb-4">
        {tags.map(tag => (
          <span class="px-2 py-0.5 rounded text-[10px] font-mono border border-zinc-800 text-zinc-500">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="text-2xl lg:text-3xl font-bold tracking-tight text-zinc-100 leading-snug mb-4">
        {title}
      </h1>
      <p class="text-zinc-400 text-sm leading-relaxed mb-5">{description}</p>
      <div class="flex items-center gap-3 text-[11px] font-mono text-zinc-600">
        <span>{formattedDate}</span>
        <span>·</span>
        <span>{readingMin} min read</span>
      </div>
    </div>

    <hr class="border-zinc-800/60 mb-10" />

    <!-- Body -->
    <article class="prose prose-invert prose-zinc max-w-none
      prose-headings:font-semibold prose-headings:tracking-tight prose-headings:text-zinc-100
      prose-h2:text-lg prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-base prose-h3:mt-7 prose-h3:mb-3
      prose-p:text-zinc-400 prose-p:leading-relaxed prose-p:text-sm
      prose-a:text-violet-400 prose-a:no-underline hover:prose-a:underline
      prose-strong:text-zinc-200 prose-strong:font-semibold
      prose-code:text-zinc-200 prose-code:text-[13px] prose-code:font-mono
      prose-code:bg-zinc-900 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none
      prose-pre:bg-zinc-900/80 prose-pre:border prose-pre:border-zinc-800/60 prose-pre:rounded-xl prose-pre:text-[13px]
      prose-table:text-sm prose-table:border-collapse
      prose-th:text-zinc-300 prose-th:font-semibold prose-th:text-left prose-th:pb-2 prose-th:border-b prose-th:border-zinc-700
      prose-td:text-zinc-400 prose-td:py-2 prose-td:border-b prose-td:border-zinc-800/50
      prose-li:text-zinc-400 prose-li:text-sm
      prose-blockquote:border-l-violet-500 prose-blockquote:text-zinc-400
      prose-hr:border-zinc-800">
      <slot />
    </article>

    <!-- Footer -->
    <div class="mt-16 pt-8 border-t border-zinc-800/50 flex items-center justify-between flex-wrap gap-4">
      <a href="/" class="flex items-center gap-2 text-xs text-zinc-500 hover:text-zinc-200 transition-colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        Back to all posts
      </a>
      <p class="font-mono text-[11px] text-zinc-700">{site.name}</p>
    </div>
  </main>
</Base>
