---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, tags } = post.data;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric',
});

const wordCount  = post.body.split(/\s+/).length;
const readingMin = Math.max(1, Math.round(wordCount / 200));
---

<a
  href={`/blog/${post.slug}`}
  class="group block p-5 rounded-xl border border-zinc-800/60 bg-zinc-900/30 hover:border-zinc-700 hover:bg-zinc-900/60 transition-all"
>
  <div class="flex flex-wrap gap-1.5 mb-3">
    {tags.map(tag => (
      <span class="px-1.5 py-0.5 rounded text-[10px] font-mono border border-zinc-800 text-zinc-600">
        {tag}
      </span>
    ))}
  </div>
  <h2 class="text-sm font-semibold text-zinc-100 group-hover:text-white transition-colors mb-2 leading-snug">
    {title}
  </h2>
  <p class="text-xs text-zinc-500 leading-relaxed mb-4 line-clamp-2">{description}</p>
  <div class="flex items-center gap-2 text-[11px] font-mono text-zinc-700">
    <span>{formattedDate}</span>
    <span>·</span>
    <span>{readingMin} min read</span>
  </div>
</a>
