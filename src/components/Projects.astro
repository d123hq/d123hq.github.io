---
import { site } from '../data/site';
---

<section id="projects" class="scroll-mt-24 reveal">
  <h2 class="font-mono text-[11px] uppercase tracking-[0.14em] text-zinc-600 mb-5">Projects</h2>
  <div class="space-y-2">
    {site.projects.map(p => (
      <div class="group p-4 rounded-xl border border-zinc-800/60 bg-zinc-900/30 hover:border-zinc-700 hover:bg-zinc-900/60 transition-all">
        <div class="flex items-start justify-between gap-4 mb-2">
          <h3 class="text-sm font-medium text-zinc-100">{p.title}</h3>
          <div class="flex gap-2 shrink-0 items-center">
            {p.github && (
              <a href={p.github} target="_blank" rel="noopener" aria-label="GitHub"
                 class="text-zinc-600 hover:text-zinc-300 transition-colors">
                <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                </svg>
              </a>
            )}
            {p.demo && (
              <a href={p.demo} target="_blank" rel="noopener" aria-label="Live demo"
                 class="text-zinc-600 hover:text-zinc-300 transition-colors">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            )}
          </div>
        </div>
        <p class="text-zinc-500 text-xs leading-relaxed mb-3">{p.desc}</p>
        <div class="flex flex-wrap gap-1.5">
          {p.tags.map(t => (
            <span class="px-1.5 py-0.5 rounded text-[10px] font-mono border border-zinc-800 text-zinc-500">{t}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
