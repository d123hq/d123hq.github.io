---
import { site } from '../data/site';

const NAV = [
  { label: 'About',      href: '#about' },
  { label: 'Skills',     href: '#skills' },
  { label: 'Projects',   href: '#projects' },
  { label: 'Experience', href: '#experience' },
  { label: 'Contact',    href: '#contact' },
];
---

<!-- Sidebar (desktop ≥1024px) -->
<aside class="hidden lg:flex flex-col fixed inset-y-0 left-0 w-56 border-r border-zinc-800/50 px-7 py-10 gap-10">
  <div>
    <p class="font-semibold text-white text-sm">{site.name}</p>
    <p class="text-xs text-zinc-500 mt-1.5 leading-snug">{site.role}</p>
  </div>

  <nav aria-label="Primary">
    <ul class="flex flex-col gap-0.5 pl-7">
      {NAV.map(({ label, href }) => (
        <li>
          <a
            href={href}
            data-section={href.slice(1)}
            class="nav-link text-xs text-zinc-500 hover:text-zinc-200 transition-colors py-1 block"
          >{label}</a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="mt-auto flex gap-2.5 items-center">
    {site.social.github && (
      <a href={site.social.github} target="_blank" rel="noopener" aria-label="GitHub"
         class="text-zinc-500 hover:text-zinc-200 transition-colors">
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    )}
    {site.social.linkedin && (
      <a href={site.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"
         class="text-zinc-500 hover:text-zinc-200 transition-colors">
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    )}
    {site.social.kaggle && (
      <a href={site.social.kaggle} target="_blank" rel="noopener" aria-label="Kaggle"
         class="text-zinc-500 hover:text-zinc-200 transition-colors">
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
          <path d="M18.825 23.859c-.022.092-.117.141-.281.141h-3.139c-.187 0-.351-.082-.492-.248l-5.178-6.589-1.448 1.374v5.111c0 .235-.117.352-.351.352H5.505c-.236 0-.354-.117-.354-.352V.353c0-.233.118-.353.354-.353h2.431c.234 0 .351.12.351.353v14.343l6.203-6.272c.165-.165.33-.246.495-.246h3.239c.144 0 .236.06.285.18.046.149.034.255-.036.315l-6.555 6.344 6.836 8.507c.095.104.117.208.07.334z"/>
        </svg>
      </a>
    )}
    {site.social.email && (
      <a href={`mailto:${site.social.email}`} aria-label="Email"
         class="text-zinc-500 hover:text-zinc-200 transition-colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
        </svg>
      </a>
    )}
  </div>
</aside>

<!-- Top bar (mobile <1024px) -->
<header class="lg:hidden sticky top-0 z-50 bg-zinc-950/95 backdrop-blur-sm border-b border-zinc-800/50">
  <div class="flex items-center justify-between h-14 px-5">
    <span class="font-mono text-sm text-white font-medium">{site.name}</span>
    <button id="mb-toggle" aria-label="Toggle navigation" aria-expanded="false"
            class="text-zinc-400 hover:text-white transition-colors p-1">
      <svg id="mb-open"  width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      <svg id="mb-close" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24" class="hidden"><path d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>
  <nav id="mb-menu" class="hidden border-t border-zinc-800/50 px-5 py-3" aria-label="Mobile">
    <ul class="flex flex-col gap-0.5">
      {NAV.map(({ label, href }) => (
        <li><a href={href} class="mb-link block py-2 text-sm text-zinc-300 hover:text-white transition-colors">{label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<script>
  // Mobile nav
  const toggle = document.getElementById('mb-toggle')!;
  const menu   = document.getElementById('mb-menu')!;
  const iconO  = document.getElementById('mb-open')!;
  const iconC  = document.getElementById('mb-close')!;

  toggle.addEventListener('click', () => {
    const hidden = menu.classList.toggle('hidden');
    iconO.classList.toggle('hidden', !hidden);
    iconC.classList.toggle('hidden', hidden);
    toggle.setAttribute('aria-expanded', String(!hidden));
  });
  document.querySelectorAll('.mb-link').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconO.classList.remove('hidden');
      iconC.classList.add('hidden');
    });
  });

  // Active sidebar link on scroll
  const sections = ['about','skills','projects','experience','contact']
    .map(id => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];
  const links = document.querySelectorAll<HTMLElement>('.nav-link');

  new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting)
        links.forEach(a => a.classList.toggle('active', a.dataset.section === e.target.id));
    });
  }, { rootMargin: '-40% 0px -55% 0px' }).observe = (function(origObserve) {
    return function(this: IntersectionObserver, target: Element) {
      return origObserve.call(this, target);
    };
  })(IntersectionObserver.prototype.observe);

  const navObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting)
        links.forEach(a => a.classList.toggle('active', a.dataset.section === e.target.id));
    });
  }, { rootMargin: '-40% 0px -55% 0px' });
  sections.forEach(s => navObs.observe(s));
</script>
